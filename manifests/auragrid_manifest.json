{
  "AppId": "aurarouter-v2",
  "Name": "AuraRouter",
  "Version": "0.5.5",
  "Description": "Multi-model routing fabric for local and cloud LLMs",
  "IsDefault": true,
  "Services": [
    {
      "MasId": "aurarouter-node",
      "DisplayName": "AuraRouter Inference Node",
      "Mode": "Distributed",
      "Runtime": "Python",
      "PythonConfig": {
        "ScriptPath": "src/aurarouter/__main__.py",
        "Arguments": "--config auraconfig.yaml",
        "WorkingDirectory": ".",
        "ManagedVenvName": "aurarouter",
        "RequirementsFile": "requirements.txt"
      }
    }
  ]
}
